{
  "name": "dental-tv",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --d1=dental-tv-db --local --ip 0.0.0.0 --port 3000",
    "prebuild": "node build-admin-css.cjs",
    "build": "vite build",
    "postbuild": "node postbuild-inline-css.cjs",
    "preview": "wrangler pages dev",
    "deploy": "npm run build && wrangler pages deploy dist",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:migrate:local": "wrangler d1 migrations apply dental-tv-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply dental-tv-db",
    "db:seed": "wrangler d1 execute dental-tv-db --local --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "hono": "^4.11.6",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-cloudflare-pages": "^0.4.3",
    "@hono/vite-dev-server": "^0.18.2",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
