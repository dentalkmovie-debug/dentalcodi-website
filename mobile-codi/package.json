{
  "name": "dental-point",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist --project-name dental-point",
    "dev:sandbox": "wrangler pages dev dist --d1=dental-point-production --local --ip 0.0.0.0 --port 3000",
    "db:migrate:local": "wrangler d1 migrations apply dental-point-production --local",
    "db:migrate:prod": "wrangler d1 migrations apply dental-point-production --remote",
    "db:seed": "wrangler d1 execute dental-point-production --local --file=./seed.sql"
  },
  "dependencies": {
    "hono": "^4.12.7"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "typescript": "^5.9.3",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
